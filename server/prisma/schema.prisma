datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String
  passwordHash      String
  role              String             @default("USER") // USER, ADMIN
  isVerified        Boolean            @default(false)
  verificationToken String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  // Relations
  histories         DetectionHistory[]
  feedbacks         Feedback[]
  auditLogs         AuditLog[]
  otps              Otp[]
  notifications     Notification[]
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DetectionHistory {
  id             String        @id @default(uuid())
  userId         String
  fileName       String
  fileType       String        // IMAGE, VIDEO, TEXT
  fileUrl        String?
  result         String        // AI, HUMAN
  confidence     Float
  processingTime Float         // in milliseconds
  createdAt      DateTime      @default(now())
  
  // Relations
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageResult    ImageResult?
  videoResult    VideoResult?
  textResult     TextResult?
}

model ImageResult {
  id                 String           @id @default(uuid())
  historyId          String           @unique
  metadata           String?          // JSON string of file metadata
  compressionFactor  Float?
  noiseScore         Float?
  ganArtifactScore   Float?
  explanation        String?
  
  // Relations
  history            DetectionHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)
}

model VideoResult {
  id                 String           @id @default(uuid())
  historyId          String           @unique
  faceConsistency    Float?
  lipSyncScore       Float?
  temporalInconsistency Float?
  suspiciousFrames   String?          // JSON string of suspicious frame numbers
  timelineAnalysis   String?          // JSON string of timeline scores
  explanation        String?
  
  // Relations
  history            DetectionHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)
}

model TextResult {
  id                 String           @id @default(uuid())
  historyId          String           @unique
  perplexity         Float?
  burstiness         Float?
  sentenceAnalysis   String?          // JSON string of sentence scores and offsets
  suspiciousParagraphs String?        // JSON string of highlighted paragraph indexes
  explanation        String?
  
  // Relations
  history            DetectionHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  category  String   // BUG, FEATURE, GENERAL
  rating    Int
  subject   String
  message   String
  createdAt DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  
  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model APIUsage {
  id             String   @id @default(uuid())
  provider       String   // GEMINI, HUGGING_FACE, MOCK
  endpoint       String
  status         Int
  processingTime Float
  createdAt      DateTime @default(now())
}
